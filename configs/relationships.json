  "composition_rules": {
    "dynamic_action": {
      "needs": ["action", "movement", "energy", "battle", "fighting"],
      "recommended": ["diagonal", "leading_lines", "dynamic_angle", "low_angle"],
      "avoid": ["static", "symmetrical", "centered"]
    },
    "calm_scene": {
      "needs": ["peaceful", "serene", "quiet", "calm", "gentle"],
      "recommended": ["symmetrical", "negative_space", "soft_light", "wide_shot"],
      "avoid": ["dynamic", "chaotic", "dramatic"]
    },
    "dramatic_moment": {
      "needs": ["dramatic", "intense", "powerful", "epic", "heroic"],
      "recommended": ["low_angle", "backlight", "high_contrast", "fill_frame"],
      "avoid": ["flat", "even", "bright"]
    },
    "intimate_scene": {
      "needs": ["romantic", "intimate", "close", "personal"],
      "recommended": ["close_up", "shallow_dof", "warm_light", "soft_focus"],
      "avoid": ["wide", "distant", "cold"]
    },
    "grand_scale": {
      "needs": ["epic", "majestic", "vast", "monumental"],
      "recommended": ["wide_angle", "low_angle", "deep_dof", "leading_lines"],
      "avoid": ["close_up", "intimate", "shallow"]
    },
    "mysterious_atmosphere": {
      "needs": ["mysterious", "enigmatic", "hidden", "secret"],
      "recommended": ["fog", "shadows", "dim_light", "partial_visibility"],
      "avoid": ["bright", "clear", "obvious"]
    },
    "energy_movement": {
      "needs": ["energy", "movement", "flow", "dynamic"],
      "recommended": ["diagonal", "motion_blur", "dynamic_angle", "leading_lines"],
      "avoid": ["static", "centered", "flat"]
    }
  },
