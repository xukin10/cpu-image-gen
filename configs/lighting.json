        "frontlight": {"name": "顺光", "keywords": ["front light", "even lighting"], "effect": "均匀、细节清晰"},
        "toplight": {"name": "顶光", "keywords": ["top light", "overhead light"], "effect": "眼窝阴影、戏剧性"},
        "underlight": {"name": "底光", "keywords": ["under light", "uplighting"], "effect": "诡异、恐怖"}
      }
    },
    "quality_light": {
      "name": "光质",
      "subcategories": {
        "soft_light": {"name": "柔光", "keywords": ["soft light", "diffused"], "effect": "柔和过渡、无硬阴影"},
        "hard_light": {"name": "硬光", "keywords": ["hard light", "sharp shadows"], "effect": "强烈对比、硬阴影"}
      }
    },
    "color_light": {
      "name": "光色",
      "subcategories": {
        "warm_light": {"name": "暖光", "keywords": ["warm light", "golden"], "effect": "温暖、舒适、怀旧"},
        "cool_light": {"name": "冷光", "keywords": ["cool light", "blue tones"], "effect": "冷静、科技、神秘"},
        "colored_light": {"name": "彩色光", "keywords": ["colored light", "neon"], "effect": "现代、科技、夜生活"}
      }
    },
    "special_lighting": {
      "name": "特殊光影",
      "effects": {
        "volumetric": {"name": "体积光", "keywords": ["volumetric light", "god rays"], "effect": "光线可见、空气感"},
        "rim_light": {"name": "轮廓光", "keywords": ["rim light", "edge light"], "effect": "主体与背景分离"},
        "neon": {"name": "霓虹", "keywords": ["neon", "neon lights"], "effect": "现代、科技、夜生活"},
        "bioluminescence": {"name": "生物荧光", "keywords": ["bioluminescence", "glow in dark"], "effect": "梦幻、神秘"}
