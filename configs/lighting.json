{
  "version": "1.0",
  "description": "光影知识库 - 帮助用户理解什么是好光影",
  "lighting_rules": {
    "natural_light": {
      "name": "自然光",
      "subcategories": {
        "golden_hour": {"name": "黄金时刻", "keywords": ["golden hour", "warm light"], "effect": "温暖、柔和、浪漫"},
        "blue_hour": {"name": "蓝色时刻", "keywords": ["blue hour", "twilight"], "effect": "冷静、神秘、梦幻"},
        "midday": {"name": "正午光", "keywords": ["midday", "harsh light"], "effect": "强烈对比、硬阴影"},
        "overcast": {"name": "阴天光", "keywords": ["overcast", "soft light"], "effect": "柔和、均匀、无阴影"}
      }
    },
    "directional_light": {
      "name": "方向光",
      "subcategories": {
